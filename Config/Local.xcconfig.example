// Local.xcconfig.example — template for local signing settings.
//
// Setup:
//   cp Config/Local.xcconfig.example Config/Local.xcconfig
//   # then set your own Apple Developer Team ID below.
//
// Config/Local.xcconfig is gitignored and must NEVER be committed.
// Find your Team ID at https://developer.apple.com/account (Membership details),
// or in Xcode > Settings > Accounts.

DEVELOPMENT_TEAM = YOUR_TEAM_ID_HERE
